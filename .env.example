# Anthropic API key — required for qualification and email writing
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude model used for prospect qualification (default: claude-haiku-4-5-20251001)
QUALIFICATION_MODEL=claude-haiku-4-5-20251001

# Claude model used for email writing (default: claude-haiku-4-5-20251001)
EMAIL_MODEL=claude-haiku-4-5-20251001

# SQLite database path (relative to project root)
DB_PATH=amorce.db

# Maximum number of URLs scraped concurrently
MAX_CONCURRENT_SCRAPES=3

# Per-page scraping timeout in seconds
SCRAPE_TIMEOUT=15

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
